# Neon / PostgreSQL（生成成功写入；首页图库读取）
DATABASE_URL=

# AceData Nano Banana
BANANA_API_KEY=
BANANA_API_URL=https://api.acedata.cloud/nano-banana/images
BANANA_SUBMIT_TIMEOUT=30
BANANA_CALLBACK_URL=

# OpenRouter（「随机灵感」调用大模型）
OPENROUTER_API_KEY=
OPENROUTER_MODEL=minimax/minimax-m2.7
# 随机灵感：推理模型易占满 token 导致 content 为空；默认 2048，可调大
OPENROUTER_INSPIRE_MAX_TOKENS=2048
# 可选：限制 reasoning 预算，如 384；或与 effort / exclude 配合（见 OpenRouter reasoning 文档）
# OPENROUTER_INSPIRE_REASONING_MAX_TOKENS=384
# OPENROUTER_INSPIRE_REASONING_EFFORT=minimal
# OPENROUTER_INSPIRE_REASONING_EXCLUDE=true
# 可选：OpenRouter 建议配置
OPENROUTER_HTTP_REFERER=https://fake-man.vercel.app
OPENROUTER_APP_TITLE=fake-man
